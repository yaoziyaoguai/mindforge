# MindForge 本地环境变量样例（Advanced / Legacy 模式）
#
# 推荐路径：通过 Web Setup (mindforge web → Setup) 配置模型。
# API key 通过 Add model 填写，保存在 local secret store (.mindforge/secrets.json)。
# .env 模式是 advanced/deployment/legacy fallback，不推荐普通用户使用。
#
# 如果必须使用 .env：
#   1. 复制本文件为 .env
#   2. 填入变量值
#   3. .env 已 gitignore，不会被提交
#
# 加载机制：CLI 入口自动加载，静默；已 export 的环境变量优先于 .env。
# 安全约束：本文件只声明变量名，绝不包含真实 key。

# Anthropic-compatible endpoint
MINDFORGE_LLM_BASE_URL=""
MINDFORGE_LLM_API_KEY=""
MINDFORGE_LLM_VERSION="2023-06-01"

# OpenAI-compatible endpoint
MINDFORGE_OPENAI_BASE_URL=""
MINDFORGE_OPENAI_API_KEY=""
MINDFORGE_OPENAI_MODEL=""

# Local LLM (Ollama/LM Studio/vLLM) — OpenAI-compatible protocol
MINDFORGE_LOCAL_LLM_BASE_URL=""
MINDFORGE_LOCAL_LLM_API_KEY=""
