# =============================================================================
# MindForge 本地环境变量样例
#
# 用法：
#   1. 复制本文件为 .env （位于项目根）
#   2. 填入真实配置（base_url / api_key 等）
#   3. .env 已在 .gitignore，永远不会被提交
#
# 加载机制（详见 src/mindforge/env_loader.py）：
#   - CLI 入口启动时自动加载 .env，**静默**（不打印任何 key/value）
#   - 已通过 shell `export` 设置的环境变量优先级**高于** .env（env > dotfile）
#
# 安全约束：
#   - 本文件只声明变量名 + 中文注释，**绝不**包含真实 key / endpoint
#   - 业务代码 / README / 测试快照都不允许出现真实 key
# =============================================================================

# -----------------------------------------------------------------------------
# 主路径：Anthropic-compatible 大模型聚合接口（v0.1 默认主路径）
# 适用：阿里云 DashScope Coding Plan 等以 Anthropic Messages API 协议暴露的服务。
# - BASE_URL 不含末尾斜杠；provider 内部会自行拼 /v1/messages
# - API_KEY  写到 x-api-key 请求头
# - VERSION  写到 anthropic-version 请求头；默认 "2023-06-01"，多数情况无需设置
#
# 与 configs/mindforge.yaml 中的 qwen_coder_fast / qwen_coder_strong 对应。
# -----------------------------------------------------------------------------
MINDFORGE_LLM_BASE_URL=""
MINDFORGE_LLM_API_KEY=""
MINDFORGE_LLM_VERSION="2023-06-01"

# -----------------------------------------------------------------------------
# 主路径模型名覆盖（可选）
# 不设则使用 mindforge.yaml 中的默认值：
#   fast   = qwen3-coder-next      （triage / link_suggestion）
#   strong = qwen3-coder-plus      （distill / review_questions / action_extraction）
# 平台支持的其他可选：qwen3.6-plus / qwen3.5-plus / qwen3-max-2026-01-23 /
#                     glm-5 / glm-4.7 / kimi-k2.5 / MiniMax-M2.5
# -----------------------------------------------------------------------------
# MINDFORGE_LLM_MODEL_FAST="qwen3-coder-next"
# MINDFORGE_LLM_MODEL_STRONG="qwen3-coder-plus"

# -----------------------------------------------------------------------------
# 备选：OpenAI-compatible 云端（OpenAI 官方 / 自建网关）
# 与 configs/mindforge.yaml 中的 openai_fast / openai_strong 对应。
# -----------------------------------------------------------------------------
MINDFORGE_OPENAI_BASE_URL=""
MINDFORGE_OPENAI_API_KEY=""

# -----------------------------------------------------------------------------
# 备选：本地 Ollama / LM Studio / vLLM（OpenAI-compatible 协议）
# 不设则用 mindforge.yaml 中的兜底 base_url（http://localhost:11434/v1）。
# 与 local_fast / local_strong 对应。api_key 可空（api_key_optional: true）。
# -----------------------------------------------------------------------------
MINDFORGE_LOCAL_LLM_BASE_URL=""
MINDFORGE_LOCAL_LLM_API_KEY=""
