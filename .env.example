# =============================================================================
# MindForge 本地环境变量样例
#
# 用法：把本文件复制为 .env，再填入自己的真实配置。
# 注意：.env 含敏感密钥，必须保留在 .gitignore 中，永远不能提交。
# 本文件只写变量名 + 中文注释，绝不包含任何真实 key / endpoint。
# =============================================================================

# -----------------------------------------------------------------------------
# Anthropic-compatible 大模型接口（v0.1 主路径）
# 适用：阿里云 DashScope Coding Plan 等以 Anthropic Messages API 协议暴露的服务。
# - BASE_URL 不含末尾斜杠；provider 内部会自行拼 /v1/messages。
# - API_KEY 写到 x-api-key 请求头。
# - VERSION 通常是 anthropic-version 请求头，缺省值 "2023-06-01"。
# -----------------------------------------------------------------------------
MINDFORGE_ANTHROPIC_BASE_URL=""
MINDFORGE_ANTHROPIC_API_KEY=""
MINDFORGE_ANTHROPIC_VERSION="2023-06-01"

# -----------------------------------------------------------------------------
# OpenAI-compatible 接口（备选路径，当前不是主路径）
# 适用：OpenAI 官方、Ollama、LM Studio、vLLM 等。
# -----------------------------------------------------------------------------
MINDFORGE_OPENAI_BASE_URL=""
MINDFORGE_OPENAI_API_KEY=""
