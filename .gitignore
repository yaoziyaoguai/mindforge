# MindForge .gitignore

# Local runtime config written by Web Setup. Use configs/mindforge_example.yaml
# as the committed template. Do NOT commit local model configuration.
configs/mindforge.yaml

# 运行时产物（M1+ 才会出现，但提前纳入忽略）
# .mindforge/ 整目录默认不入库：
#   - .mindforge/state.json     是本地 checkpoint，含个人知识库的扫描状态
#   - .mindforge/runs/*.jsonl   是本地 observer / event log，含路径与时间戳
#   - .mindforge/telemetry.jsonl 是本地使用 telemetry（M5.7 / v0.2.3，**不上传**）
#   - .mindforge/*.bak          是 state.json 的原子写备份
# 这些都是 per-machine 的运行痕迹，不应进 git。
.mindforge/
.mindforge/runs/
.mindforge/telemetry.jsonl
*.log

# Python
.venv/
venv/
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
dist/
build/

# Web frontend
web/node_modules/
web/tsconfig.tsbuildinfo
!web/dist/
!web/dist/**

# uv / pip-tools
.uv-cache/
pip-wheel-metadata/

# Tests
.pytest_cache/
.coverage
htmlcov/
.tox/

# Editors / OS
.idea/
.vscode/
.DS_Store
Thumbs.db

# Local user scratch
scratch/
local/
*.local.*

# Local Claude Code / agent environment file. Never commit.
claude-code-agent-env

# Secrets：本地 .env（含 API key、base_url 等）严禁入库
# 例外：.env.example 仅含变量名 + 中文注释，可入库
.env
.env.*
!.env.example

# Obsidian Vault 占位（vault_template/ 仅做模板，本仓库不放真实笔记）
vault_template/00-Inbox/**/!(.gitkeep|README.md)
vault_template/20-Knowledge-Cards/**/!(.gitkeep|README.md)

# v0.4.2: demo vault 跑 smoke 时会产生的本地状态（不入仓库）
examples/demo-vault/.mindforge/

# vault/ 是本地运行时知识库目录，每台机器独立，严禁入库。
# 模板在 vault_template/，包含 README 和 .gitkeep 占位文件。
# 用户运行 mindforge init 后会在本地创建 vault/，不应被 git track。
vault/
vault/**/.mindforge/
