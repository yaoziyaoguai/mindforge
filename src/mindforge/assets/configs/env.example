# MindForge local environment.
# Copy this file to .env or export these variables in your shell.
# Do not commit real API keys.

# OpenAI-compatible provider
MINDFORGE_OPENAI_API_KEY=your-openai-compatible-api-key
MINDFORGE_OPENAI_BASE_URL=https://api.openai.com/v1
MINDFORGE_OPENAI_MODEL=gpt-4o-mini

# Anthropic provider
MINDFORGE_ANTHROPIC_API_KEY=your-anthropic-api-key
MINDFORGE_ANTHROPIC_BASE_URL=https://api.anthropic.com
MINDFORGE_ANTHROPIC_MODEL=claude-3-5-haiku-latest
